# Formspree — Créer un compte sur https://formspree.io et remplacer par votre ID de formulaire
# Exemple : VITE_FORMSPREE_ID=xpwzygkd
VITE_FORMSPREE_ID=your_formspree_id_here

# Cal.com — Créer un compte gratuit sur https://cal.com, connecter Google Calendar,
# créer un Event Type et indiquer ici le lien (username/event-slug)
# Exemple : VITE_CALCOM_LINK=maisonmikasa/consultation
VITE_CALCOM_LINK=your_calcom_username/your_event_slug
